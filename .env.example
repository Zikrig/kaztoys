# Telegram Bot
BOT_TOKEN=your_bot_token_here

# PostgreSQL (used by docker-compose for postgres service)
POSTGRES_USER=kaztoys
POSTGRES_PASSWORD=changeme
POSTGRES_DB=kaztoys

# Application DB URL (use postgres hostname in Docker, localhost when running locally)
DATABASE_URL=postgresql+asyncpg://kaztoys:changeme@postgres:5432/kaztoys

# Referral link parameter name (e.g. ?ref=123)
REFERRAL_PARAM=ref
INSTAGRAM_PARAM=insta
REFERRAL_BONUS_DAYS=7

# Support contact (e.g. @support_username)
SUPPORT_CONTACT=@support

# Path to onboarding video (inside container or relative to project root)
VIDEO_INSTRUCTION_PATH=assets/video_instruction.mp4

# Inactivity timeout in minutes before returning to main menu
INACTIVITY_MINUTES=10

# Comma-separated Telegram user IDs with admin access
ADMIN_IDS=328934,345989
